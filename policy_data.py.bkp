SCENARIO_NOTES = {
    "Current law": (
        "Negative gearing remains available, and mainstream individual CGT settings remain broadly similar for direct "
        "property and shares."
    ),
    "No negative gearing": (
        "Stress test only. Rental losses are assumed not to offset salary or wages. This usually makes low-yield "
        "property materially less attractive unless rent growth or capital growth is strong."
